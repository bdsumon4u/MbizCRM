<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep Authorization header for API/authenticated requests
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # If request is already for /public, do nothing
    RewriteCond %{REQUEST_URI} !^/public/

    # Route every request through /public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
